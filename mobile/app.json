{
  "expo": {
    "name": "GrabVid",
    "slug": "grabvid",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "grabvid",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.grabvid.app",
      "infoPlist": {
        "NSPhotoLibraryAddUsageDescription": "GrabVid needs access to save downloaded media to your Photos library.",
        "NSPhotoLibraryUsageDescription": "GrabVid needs access to save downloaded media to your Photos library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.grabvid.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0B"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "INTERNET",
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_VIDEO",
        "READ_MEDIA_AUDIO",
        "READ_MEDIA_IMAGES",
        "VIBRATE"
      ],
      "intentFilters": [
        {
          "action": "android.intent.action.SEND",
          "category": [
            "android.intent.category.DEFAULT"
          ],
          "data": [
            {
              "mimeType": "text/plain"
            }
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow GrabVid to save downloaded media to your photo library.",
          "savePhotosPermission": "Allow GrabVid to save downloaded media to your photo library."
        }
      ],
      [
        "expo-sqlite",
        {}
      ],
      "expo-font"
    ]
  }
}
